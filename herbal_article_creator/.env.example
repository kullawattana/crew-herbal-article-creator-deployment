# ===========================================
# CrewAI Herbal Article Creator Configuration
# ===========================================
OUTPUT_LANG=en #en,th

LLM_MODEL_NAME="llama"
#LLM_MODEL_NAME="gemini"
#LLM_MODEL_NAME="gpt"
#LLM_MODEL_NAME="anthropic"

LLM_TEMPERATURE="0.6"       #It is a parameter that controls the level of randomness in generating the next word.
LLM_TOP_P="0.9"             #It is a parameter used to filter possible words by selecting those whose cumulative probability adds up to the specified top_p value.
LLM_MAX_TOKENS="8192"       #Maximum number of tokens to generate in the response. The total length of input tokens and generated tokens should not exceed the model's context length. (0, 1024, 2048, 4096, 8192, 16384, 32768)

# --- LLM LLAMA (Nvidia) ---
LLM_MODEL="meta/llama-3.3-70b-instruct"     #standard model
LLM_API_KEY=nvapi-xxx

#LLM_LLAMA_MODEL="meta/llama-3.2-1b-instruct"
#LLM_LLAMA_MODEL="meta/llama-3.2-3b-instruct"
#LLM_LLAMA_MODEL="meta/llama-3.1-8b-instruct"
#LLM_LLAMA_MODEL="meta/llama-3.1-405b-instruct"
LLM_LLAMA_MODEL="meta/llama-3.1-70b-instruct"
NVIDIA_NIM_API_KEY=nvapi-xxx
LLM_PROVIDER=
LLM_API_BASE=https://integrate.api.nvidia.com/v1

# --- LLM GEMINI Configuration ---
#LLM_GEMINI_MODEL="gemini/gemini-1.5-flash"
#LLM_GEMINI_MODEL="gemini/gemini-1.5-pro"
LLM_GEMINI_MODEL="gemini/gemini-2.0-flash"
#LLM_GEMINI_MODEL="gemini/gemini-2.0-pro"
#LLM_GEMINI_MODEL="gemini/gemini-2.5-flash"
#LLM_GEMINI_MODEL="gemini/gemini-2.5-pro"
GEMINI_API_KEY=AIxxx

# --- LLM GPT Configuration ---
#LLM_GPT_MODEL="gpt-4o"
LLM_GPT_MODEL="gpt-4o-mini"
#LLM_GPT_MODEL="gpt-4.1"
#LLM_GPT_MODEL="gpt-4.1-mini"
#LLM_GPT_MODEL="gpt-4.1-nano"
OPENAI_API_KEY=ab-proj-xxx

# --- LLM Anthropic Configuration ---
LLM_CLAUDE_MODEL="claude-3-7-sonnet-latest"
ANTHROPIC_API_KEY=ab-ant-api03-xxx

#--- Pubmed --- 
NCBI_API_KEY=xxx
PUBMED_CONTACT_EMAIL="abc@gmail.com"
PUBMED_POLITE_DELAY="0.2"

#--- Tavily Search --- 
TAVILY_API_KEY="tvly-dev-xxx"

