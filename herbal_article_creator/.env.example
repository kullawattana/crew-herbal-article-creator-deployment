# ===========================================
# CrewAI Herbal Article Creator Configuration
# ===========================================
OUTPUT_LANG=en #en,th

# ===========================================
# CrewAI Herbal Article Creator LLM_MODE Configuration (blind, global [ใช้ model เดียวทั้ง flow])
# ===========================================
#LLM_MODE="global" 
#LLM_MODE="blind_group_A"        #A llama 3.1
LLM_MODE="blind_group_B"         #B claude 
#LLM_MODE="blind_group_C"        #C gemini  
#LLM_MODE="blind_group_D"        #D gpt-4.1
#LLM_MODE="blind_group_E"        #E llama 3.3

# CrewAI Herbal Article Creator Model Configuration for LLM_MODE="global"
#LLM_MODEL_NAME="llama"
LLM_MODEL_NAME="gemini"
#LLM_MODEL_NAME="gpt"
#LLM_MODEL_NAME="anthropic"

# ===========================================
# CrewAI Herbal Article Creator Log Configuration
# ===========================================
LANGFUSE_LOG_OPEN="false" # true, false

# ===========================================
# CrewAI Herbal Article Creator Parameter Configuration
# ===========================================
LLM_TEMPERATURE="0.6"       
LLM_TOP_P="0.9"             
#LLM_MAX_TOKENS="4096"
LLM_MAX_TOKENS="8192"

# --- LLM LLAMA (Nvidia) ---
#LLM_LLAMA_MODEL="meta/llama-3.2-1b-instruct"
#NVIDIA_NIM_API_KEY=nvapi-xxx

#LLM_LLAMA_MODEL="meta/llama-3.2-3b-instruct"
#NVIDIA_NIM_API_KEY=nvapi-xxx

#LLM_LLAMA_MODEL="meta/llama-3.1-8b-instruct"
#NVIDIA_NIM_API_KEY=nvapi-xxx

LLM_LLAMA_MODEL="meta/llama-3.1-70b-instruct"
NVIDIA_NIM_API_KEY=nvapi-xxx

LLM_MODEL="meta/llama-3.3-70b-instruct"
LLM_API_KEY=nvapi-xxx

#LLM_LLAMA_MODEL="meta/llama-3.1-405b-instruct"
#NVIDIA_NIM_API_KEY=nvapi-xxx

LLM_PROVIDER=
LLM_API_BASE=https://integrate.api.nvidia.com/v1

# --- LLM GPT OSS (Nvidia) ---
#LLM_NVIDIA_GPT_OSS_MODEL="openai/gpt-oss-120b"
#LLM_NVIDIA_GPT_OSS_API_KEY=nvapi-xxx
#LLM_API_BASE=https://integrate.api.nvidia.com/v1
#LLM_PROVIDER=

#LLM_NVIDIA_GPT_OSS_MODEL="gpt-oss-20b-instruct"
#LLM_NVIDIA_API_KEY=nvapi-xxx
#LLM_API_BASE=https://integrate.api.nvidia.com/v1
#LLM_PROVIDER=

# --- LLM GEMINI Configuration ---
#LLM_GEMINI_MODEL="gemini/gemini-1.5-flash"
#LLM_GEMINI_MODEL="gemini/gemini-1.5-pro"
#LLM_GEMINI_MODEL="gemini/gemini-2.0-flash"
#LLM_GEMINI_MODEL="gemini/gemini-2.0-pro"
#LLM_GEMINI_MODEL="gemini/gemini-2.5-flash"
#LLM_GEMINI_MODEL="gemini/gemini-2.5-pro"
GEMINI_API_KEY=AIxxx

# --- LLM GPT Configuration ---
#LLM_GPT_MODEL="gpt-4o"
#LLM_GPT_MODEL="gpt-4o-mini"
#LLM_GPT_MODEL="gpt-5.2"
LLM_GPT_MODEL="gpt-4.1"
OPENAI_API_KEY=sk-proj--xxx
# --- LLM Anthropic Configuration ---
# Not use in crewAI
LLM_CLAUDE_MODEL="claude-haiku-4-5-20251001"
ANTHROPIC_API_KEY=sk-ant-xxx

# --- LLM EVALUATION --- 
# use final version only
#EVAL_MODEL="gemini-2.5-flash"

#--- Pubmed --- 
NCBI_API_KEY=xxx
PUBMED_CONTACT_EMAIL="abc@gmail.com"
PUBMED_POLITE_DELAY="0.2"

#--- Tavily Search --- 
TAVILY_API_KEY="tvly-dev-xxx"

#--- Research Topics --- 
