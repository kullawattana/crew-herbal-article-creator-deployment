# --- Google API (for Gemini Embeddings) ---
GOOGLE_API_KEY=AIxxx

# ===========================================
# PINECONE VECTOR DATABASE CONFIGURATION
# ===========================================

# Pinecone API credentials
PINECONE_API_KEY=pcab_xxx
PINECONE_INDEX_NAME=herbalindex
PINECONE_NAMESPACE="__default__"

# Embedding model configuration
PINECONE_EMBED_MODEL=text-embedding-004
PINECONE_DIMENSION=768

# Search parameters
PINECONE_TOP_K=5  #The model filters the list of possible words down to only the top K most probable ones, and then randomly selects from within this group only.
PINECONE_SNIPPET_LIMIT=240
PINECONE_TOTAL_LIMIT=6000

# Context building
PINECONE_BUILD_INITIAL_CONTEXT=true
PINECONE_CONTEXT_TOP_K=20
PINECONE_CONTEXT_MAX_CHARS=8000

# ===========================================
# Google Drive authrorize
# ===========================================
GOOGLE_FOLDER_ID="" #read pdf
#authrorize google drive with convert service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON_PATH="data/credentials/gdrive_service_account.json"
#authrorize google drive with convert service_account.json -> base64 string
GOOGLE_SERVICE_ACCOUNT_JSON_B64=""

# ===========================================
# Google Drive upload file
# ===========================================
GDRIVE_UPLOAD_FOLDER_ID = ""
GDRIVE_CLIENT_SECRET_PATH="data/credentials/client_secrete_gdrive_desktop.json"